background: linear-gradient(135deg,#0f2027,#203a43,#2c5364);
color:white;
text-align:center;
}

.container{
width:90%;
max-width:400px;
margin:auto;
margin-top:40px;
background:#2d3142;
padding:20px;
border-radius:15px;
}

input{
width:90%;
padding:12px;
margin:10px;
border-radius:10px;
border:none;
}

button{
padding:12px 30px;
border:none;
border-radius:20px;
background:linear-gradient(90deg,#1e90ff,#ff6a6a);
